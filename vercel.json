{
  "version": 2,
  "builds": [
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "runtime": "vercel-python@0.9.2" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "japhestech.settings",
    "SECRET_KEY": "your-secret-key",
    "DEBUG": "False",
    "VERCEL_URL": "japhestech.vercel.app"
  }
}